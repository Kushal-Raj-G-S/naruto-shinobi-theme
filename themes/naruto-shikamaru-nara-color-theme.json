	"tokenColors": [
		{
			"name": "Comments - Lazy thoughts",
			"scope": ["comment", "punctuation.definition.comment"],
			"settings": {
				"foreground": "#5a5a5a",
				"fontStyle": "italic"
			}
		},
		{
			"name": "Keywords - SHADOW ESSENCE",
			"scope": ["keyword", "storage.type", "storage.modifier"],
			"settings": {
				"foreground": "#808080",
				"fontStyle": "bold"
			}
		},
		{
			"name": "Control Flow - STRATEGIC CONTROL",
			"scope": ["keyword.control", "keyword.operator"],
			"settings": {
				"foreground": "#A9A9A9",
				"fontStyle": "bold"
			}
		},
		{
			"name": "Import/Export - SHADOW SUMMONING",
			"scope": [
				"keyword.control.import",
				"keyword.control.export",
				"keyword.control.from",
				"keyword.control.as"
			],
			"settings": {
				"foreground": "#6B8E23",
				"fontStyle": ""
			}
		},
		{
			"name": "Strings - FOREST STRATEGY GREEN",
			"scope": ["string", "string.quoted"],
			"settings": {
				"foreground": "#8B9A6B"
			}
		},
		{
			"name": "Template Strings - TACTICAL INCANTATION",
			"scope": ["string.template", "string.quoted.template"],
			"settings": {
				"foreground": "#9ACD32"
			}
		},
		{
