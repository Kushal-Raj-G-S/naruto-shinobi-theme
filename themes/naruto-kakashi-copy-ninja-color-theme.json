	"tokenColors": [
		{
			"name": "Comments - Faded memories",
			"scope": ["comment", "punctuation.definition.comment"],
			"settings": {
				"foreground": "#6a6a6a",
				"fontStyle": "italic"
			}
		},
		{
			"name": "Keywords - Essential lightning jutsu",
			"scope": ["keyword", "storage.type", "storage.modifier"],
			"settings": {
				"foreground": "#E0E0E0",
				"fontStyle": "bold"
			}
		},
		{
			"name": "Control Flow - Tactical decisions",
			"scope": ["keyword.control", "keyword.operator"],
			"settings": {
				"foreground": "#C0C0C0",
				"fontStyle": "bold"
			}
		},
		{
			"name": "Import/Export - Summoning jutsu",
			"scope": [
				"keyword.control.import",
				"keyword.control.export",
				"keyword.control.from",
				"keyword.control.as"
			],
			"settings": {
				"foreground": "#A8A8A8",
				"fontStyle": ""
			}
		},
		{
			"name": "Strings - Scroll wisdom",
			"scope": ["string", "string.quoted"],
			"settings": {
				"foreground": "#D2B48C"
			}
		},
		{
			"name": "Template Strings - Written technique",
