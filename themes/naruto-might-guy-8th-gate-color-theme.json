	"tokenColors": [
		{
			"name": "Comments - DYING THOUGHTS",
			"scope": ["comment", "punctuation.definition.comment"],
			"settings": {
				"foreground": "#8a4a4a",
				"fontStyle": "italic"
			}
		},
		{
			"name": "Keywords - BLOOD ESSENCE",
			"scope": ["keyword", "storage.type", "storage.modifier"],
			"settings": {
				"foreground": "#8B0000",
				"fontStyle": "bold"
			}
		},
		{
			"name": "Control Flow - DEATH MOVES",
			"scope": ["keyword.control", "keyword.operator"],
			"settings": {
				"foreground": "#DC143C",
				"fontStyle": "bold"
			}
		},
		{
			"name": "Import/Export - DRAGON SUMMONING",
			"scope": [
				"keyword.control.import",
				"keyword.control.export",
				"keyword.control.from",
				"keyword.control.as"
			],
			"settings": {
				"foreground": "#FF0000",
				"fontStyle": "bold"
			}
		},
		{
			"name": "Strings - STEAM WHITE",
			"scope": ["string", "string.quoted"],
			"settings": {
				"foreground": "#FFFFFF"
			}
		},
		{
			"name": "Template Strings - BURNING WORDS",
			"scope": ["string.template", "string.quoted.template"],
			"settings": {
				"foreground": "#FFE4E1"
			}
		},
		{
			"name": "String Escape - NIGHT GUY",
			"scope": ["constant.character.escape"],
			"settings": {
				"foreground": "#FF0000",
				"fontStyle": "bold"
			}
		},
		{
			"name": "Regex - DRAGON PATTERN",
			"scope": ["string.regexp"],
			"settings": {
				"foreground": "#FF6347"
			}
		},
		{
			"name": "Numbers - DEATH COUNT",
			"scope": ["constant.numeric", "constant.language"],
			"settings": {
				"foreground": "#FFFFFF",
				"fontStyle": "bold"
			}
		},
		{
			"name": "Booleans - LIFE OR DEATH",
			"scope": ["constant.language.boolean"],
			"settings": {
				"foreground": "#FF4500",
				"fontStyle": "bold"
			}
		},
		{
			"name": "Variables - CRIMSON POWER",
			"scope": ["variable", "variable.other"],
			"settings": {
				"foreground": "#DC143C",
				"fontStyle": "bold"
			}
		},
		{
			"name": "Parameters - TECHNIQUE FINAL",
			"scope": ["variable.parameter"],
			"settings": {
				"foreground": "#FF6347",
				"fontStyle": "italic"
			}
		},
		{
			"name": "Properties - BODY DESTRUCTION",
			"scope": ["variable.other.property", "support.variable.property"],
			"settings": {
				"foreground": "#B22222"
			}
		},
		{
			"name": "Functions - RED DRAGON FLAME",
			"scope": ["entity.name.function", "support.function"],
			"settings": {
				"foreground": "#FF0000",
				"fontStyle": "bold"
			}
		},
		{
			"name": "Function Calls - DEATH ATTACKS",
			"scope": ["meta.function-call"],
			"settings": {
				"foreground": "#DC143C"
			}
		},
		{
			"name": "Classes - MIDNIGHT BLUE",
			"scope": ["entity.name.type", "entity.name.class", "support.class"],
			"settings": {
				"foreground": "#000080",
				"fontStyle": ""
			}
		},
		{
			"name": "Inherited Classes - MADARA LEGACY",
