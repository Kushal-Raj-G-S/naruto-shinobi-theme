	"tokenColors": [
		{
			"name": "Comments - Destroyed by fury",
			"scope": ["comment", "punctuation.definition.comment"],
			"settings": {
				"foreground": "#6a4030",
				"fontStyle": "italic"
			}
		},
		{
			"name": "Keywords - Crimson demon eyes",
			"scope": ["keyword", "storage.type", "storage.modifier"],
			"settings": {
				"foreground": "#DC143C",
				"fontStyle": "bold"
			}
		},
		{
			"name": "Control Flow - Tail whip strikes",
			"scope": ["keyword.control", "keyword.operator"],
			"settings": {
				"foreground": "#ff4466",
				"fontStyle": "bold"
			}
		},
		{
			"name": "Import/Export - Chakra linking",
			"scope": [
				"keyword.control.import",
				"keyword.control.export",
				"keyword.control.from",
				"keyword.control.as"
			],
			"settings": {
				"foreground": "#FF8C00",
				"fontStyle": ""
			}
		},
		{
			"name": "Strings - Flame ribbons",
			"scope": ["string", "string.quoted"],
			"settings": {
				"foreground": "#FFA500"
			}
		},
		{
			"name": "Template Strings - Swirling fire",
			"scope": ["string.template", "string.quoted.template"],
			"settings": {
				"foreground": "#ffaa44"
			}
		},
		{
			"name": "String Escape - Explosive burst",
