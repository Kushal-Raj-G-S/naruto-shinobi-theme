  "tokenColors": [
    {
      "name": "Comments",
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#8B9A8B",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Documentation Comments",
      "scope": [
        "comment.block.documentation",
        "comment.line.documentation"
      ],
      "settings": {
        "foreground": "#A0B5A0",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Keywords",
      "scope": [
        "keyword",
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#4A7C59",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Control Keywords",
      "scope": [
        "keyword.control",
        "keyword.control.flow"
      ],
      "settings": {
        "foreground": "#5A8C6A",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Import/Export Keywords",
      "scope": [
        "keyword.control.import",
        "keyword.control.export",
        "keyword.control.from"
      ],
      "settings": {
        "foreground": "#4A7C59"
      }
    },
    {
      "name": "Strings",
      "scope": [
        "string",
        "string.quoted",
        "string.quoted.double",
        "string.quoted.single",
        "string.quoted.triple"
      ],
      "settings": {
        "foreground": "#7FAF6E"
      }
    },
    {
      "name": "Template Strings",
      "scope": [
        "string.template",
        "string.quoted.template"
      ],
      "settings": {
        "foreground": "#7FAF6E"
      }
    },
    {
      "name": "String Escape Sequences",
      "scope": [
        "constant.character.escape",
        "constant.other.placeholder"
      ],
      "settings": {
        "foreground": "#94C583",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Regular Expressions",
      "scope": [
        "string.regexp"
      ],
      "settings": {
        "foreground": "#94C583"
      }
    },
    {
      "name": "Functions & Methods",
      "scope": [
        "entity.name.function",
        "support.function",
        "meta.function-call.generic"
      ],
      "settings": {
        "foreground": "#9D7F6A"
      }
    },
    {
      "name": "Function Calls",
      "scope": [
        "meta.function-call"
      ],
      "settings": {
        "foreground": "#B89885"
      }
    },
    {
      "name": "Function Parameters",
      "scope": [
        "variable.parameter",
        "meta.parameters"
      ],
      "settings": {
        "foreground": "#84B598"
      }
    },
    {
      "name": "Variables",
      "scope": [
        "variable",
        "support.variable"
      ],
      "settings": {
        "foreground": "#84B598"
      }
    },
    {
      "name": "Variable Declarations",
      "scope": [
        "variable.other.declaration",
        "meta.definition.variable"
      ],
      "settings": {
        "foreground": "#6B9F7F"
      }
    },
    {
      "name": "Object Properties",
      "scope": [
        "variable.object.property",
        "variable.other.property",
        "meta.object-literal.key"
      ],
      "settings": {
        "foreground": "#6B9F7F"
      }
    },
    {
      "name": "This/Self Keywords",
      "scope": [
        "variable.language.this",
        "variable.language.self",
        "variable.language.super"
      ],
      "settings": {
        "foreground": "#5A8C6A",
        "fontStyle": "italic bold"
      }
    },
    {
      "name": "Classes & Types",
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "support.class",
        "entity.other.inherited-class"
