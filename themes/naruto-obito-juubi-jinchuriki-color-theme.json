	"tokenColors": [
		{
			"name": "Comments - Broken memories",
			"scope": ["comment", "punctuation.definition.comment"],
			"settings": {
				"foreground": "#6a7398",
				"fontStyle": "italic"
			}
		},
		{
			"name": "Keywords - Kamui verdict",
			"scope": ["keyword", "storage.type", "storage.modifier", "keyword.control", "keyword.operator"],
			"settings": {
				"foreground": "#9faeff",
				"fontStyle": "bold"
			}
		},
		{
			"name": "Strings",
			"scope": ["string", "string.quoted", "string.template"],
			"settings": {
				"foreground": "#d4dcff"
			}
		},
		{
			"name": "Numbers and constants",
			"scope": ["constant.numeric", "constant.language", "support.constant"],
			"settings": {
				"foreground": "#ffd166",
				"fontStyle": "bold"
			}
		},
		{
			"name": "Variables",
			"scope": ["variable", "variable.other", "variable.other.property"],
			"settings": {
				"foreground": "#e8ebf8"
			}
		},
		{
			"name": "Parameters",
			"scope": ["variable.parameter", "variable.language.this"],
			"settings": {
				"foreground": "#bac5ea",
				"fontStyle": "italic"
			}
		},
		{
			"name": "Functions",
			"scope": ["entity.name.function", "support.function", "meta.function-call"],
			"settings": {
				"foreground": "#7f9bff",
				"fontStyle": "bold"
			}
		},
		{
			"name": "Types and classes",
			"scope": ["entity.name.type", "entity.name.class", "support.class", "entity.name.namespace"],
			"settings": {
				"foreground": "#5d3fd3"
			}
		},
		{
			"name": "Tags and attributes",
			"scope": ["entity.name.tag", "entity.other.attribute-name"],
			"settings": {
				"foreground": "#9faeff"
			}
		},
		{
			"name": "Punctuation and braces",
			"scope": ["punctuation", "punctuation.section", "meta.brace"],
			"settings": {
				"foreground": "#a5afd2"
			}
		},
		{
			"name": "Invalid",
			"scope": ["invalid", "invalid.deprecated"],
			"settings": {
				"foreground": "#ffffff",
				"background": "#5d3fd3"
			}
		},
		{
			"name": "Markdown headings",
			"scope": ["markup.heading", "markup.bold"],
			"settings": {
				"foreground": "#9faeff",
				"fontStyle": "bold"
			}
		},
		{
			"name": "Markdown emphasis",
			"scope": ["markup.italic", "markup.inline.raw", "markup.underline.link", "markup.list"],
			"settings": {
				"foreground": "#d4dcff"
			}
		},
		{
			"name": "Diff",
			"scope": ["markup.inserted", "markup.deleted", "markup.changed"],
			"settings": {
				"foreground": "#ffd166"
			}
		},
		{
			"name": "Decorators and annotations",
			"scope": ["meta.decorator", "punctuation.decorator", "storage.type.annotation", "punctuation.definition.annotation"],
			"settings": {
				"foreground": "#5d3fd3",
				"fontStyle": "italic"
			}
		}
	]
}
