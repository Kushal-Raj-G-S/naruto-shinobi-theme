			"settings": {
				"foreground": "#B22222"
			}
		},
		{
			"name": "Support Types - ANBU TOOLS",
			"scope": ["support.type", "support.class"],
			"settings": {
				"foreground": "#6A0DAD"
			}
		},
		{
			"name": "Support Constants - ILLNESS GRAY",
			"scope": ["support.constant"],
			"settings": {
