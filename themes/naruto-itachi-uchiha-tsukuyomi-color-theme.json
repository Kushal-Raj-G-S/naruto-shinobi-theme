	"tokenColors": [
		{
			"name": "Comments - Hidden truth",
			"scope": ["comment", "punctuation.definition.comment"],
			"settings": {
				"foreground": "#5a3a3a",
				"fontStyle": "italic"
			}
		},
		{
			"name": "Keywords - MANGEKYO PATTERN",
			"scope": ["keyword", "storage.type", "storage.modifier"],
			"settings": {
				"foreground": "#8B0000",
				"fontStyle": "bold"
			}
		},
		{
			"name": "Control Flow - GENJUTSU WEAVING",
			"scope": ["keyword.control", "keyword.operator"],
			"settings": {
				"foreground": "#DC143C",
				"fontStyle": "bold"
			}
		},
		{
			"name": "Import/Export - CROW SUMMONING",
			"scope": [
				"keyword.control.import",
				"keyword.control.export",
				"keyword.control.from",
				"keyword.control.as"
			],
			"settings": {
				"foreground": "#000000",
				"fontStyle": ""
			}
		},
		{
			"name": "Strings - BLOOD CRIMSON",
			"scope": ["string", "string.quoted"],
			"settings": {
				"foreground": "#DC143C"
			}
		},
		{
			"name": "Template Strings - SACRIFICE WORDS",
			"scope": ["string.template", "string.quoted.template"],
			"settings": {
				"foreground": "#B22222"
			}
		},
		{
			"name": "String Escape - TSUKUYOMI BREAK",
			"scope": ["constant.character.escape"],
			"settings": {
				"foreground": "#8B008B",
				"fontStyle": "bold"
			}
		},
		{
			"name": "Regex - AMATERASU PATTERN",
			"scope": ["string.regexp"],
			"settings": {
				"foreground": "#4B0082"
			}
		},
		{
			"name": "Numbers - DEATH COUNT",
			"scope": ["constant.numeric", "constant.language"],
			"settings": {
				"foreground": "#d8d8d8",
				"fontStyle": "bold"
			}
		},
		{
			"name": "Booleans - TRUTH OR LIE",
			"scope": ["constant.language.boolean"],
			"settings": {
				"foreground": "#6A0DAD",
				"fontStyle": "bold"
			}
		},
		{
			"name": "Variables - SHARINGAN RED",
			"scope": ["variable", "variable.other"],
			"settings": {
				"foreground": "#DC143C",
				"fontStyle": ""
			}
		},
		{
			"name": "Parameters - TECHNIQUE COMPONENTS",
			"scope": ["variable.parameter"],
			"settings": {
				"foreground": "#B22222",
				"fontStyle": "italic"
			}
		},
		{
			"name": "Properties - UCHIHA TRAITS",
			"scope": ["variable.other.property", "support.variable.property"],
			"settings": {
				"foreground": "#8B0000"
			}
		},
		{
			"name": "Functions - CROW BLACK",
			"scope": ["entity.name.function", "support.function"],
			"settings": {
				"foreground": "#1C1C1C",
				"fontStyle": "bold"
			}
		},
		{
			"name": "Function Calls - JUTSU EXECUTION",
			"scope": ["meta.function-call"],
			"settings": {
				"foreground": "#2a2a2a"
			}
		},
		{
			"name": "Classes - PURPLE VOID",
			"scope": ["entity.name.type", "entity.name.class", "support.class"],
			"settings": {
				"foreground": "#6A0DAD",
				"fontStyle": ""
			}
		},
		{
			"name": "Inherited Classes - UCHIHA LEGACY",
			"scope": ["entity.other.inherited-class"],
			"settings": {
				"foreground": "#8B008B",
				"fontStyle": "italic"
			}
		},
		{
			"name": "HTML Tags - BLOOD SEAL",
			"scope": ["entity.name.tag"],
			"settings": {
				"foreground": "#8B0000",
				"fontStyle": "bold"
			}
		},
		{
			"name": "HTML Attributes - MASSACRE MARKS",
			"scope": ["entity.other.attribute-name"],
			"settings": {
				"foreground": "#B22222",
				"fontStyle": "italic"
