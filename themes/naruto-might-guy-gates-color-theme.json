	"tokenColors": [
		{
			"name": "Comments - Memories of springtime",
			"scope": ["comment", "punctuation.definition.comment"],
			"settings": {
				"foreground": "#5a8a5a",
				"fontStyle": "italic"
			}
		},
		{
			"name": "Keywords - BURNING RED ESSENCE",
			"scope": ["keyword", "storage.type", "storage.modifier"],
			"settings": {
				"foreground": "#DC143C",
				"fontStyle": "bold"
			}
		},
		{
			"name": "Control Flow - TAIJUTSU MOVES",
			"scope": ["keyword.control", "keyword.operator"],
			"settings": {
				"foreground": "#FF4500",
				"fontStyle": "bold"
			}
		},
		{
			"name": "Import/Export - SUMMONING TECHNIQUE",
			"scope": [
				"keyword.control.import",
				"keyword.control.export",
				"keyword.control.from",
				"keyword.control.as"
			],
			"settings": {
				"foreground": "#32CD32",
				"fontStyle": ""
			}
		},
		{
			"name": "Strings - YELLOW ENTHUSIASM",
			"scope": ["string", "string.quoted"],
			"settings": {
				"foreground": "#FFD700"
			}
		},
		{
			"name": "Template Strings - SHINING WORDS",
			"scope": ["string.template", "string.quoted.template"],
			"settings": {
				"foreground": "#FFEA00"
			}
		},
		{
