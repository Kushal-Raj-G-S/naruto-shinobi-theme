	"tokenColors": [
		{
			"scope": ["comment", "punctuation.definition.comment"],
			"settings": {
				"foreground": "#5a5a7a",
				"fontStyle": "italic"
			}
		},
		{
			"name": "Keywords - Sharingan power",
			"scope": ["keyword", "storage.type", "storage.modifier"],
			"settings": {
				"foreground": "#FF0066",
				"fontStyle": "bold"
			}
		},
		{
			"name": "Control Flow - Lightning blade strikes",
			"scope": ["keyword.control", "keyword.operator"],
			"settings": {
				"foreground": "#8b00ff",
				"fontStyle": "bold"
			}
		},
		{
			"name": "Import/Export - Dimensional portals",
			"scope": [
				"keyword.control.import",
				"keyword.control.export",
				"keyword.control.from",
				"keyword.control.as"
			],
			"settings": {
				"foreground": "#9370DB",
				"fontStyle": ""
			}
		},
		{
			"name": "Strings - Chidori lightning",
			"scope": ["string", "string.quoted"],
			"settings": {
				"foreground": "#4169E1"
			}
		},
		{
			"name": "Template Strings - Electric chakra",
			"scope": ["string.template", "string.quoted.template"],
			"settings": {
				"foreground": "#5a8aff"
			}
		},
		{
			"name": "String Escape - Kirin dragon",
			"scope": ["constant.character.escape"],
			"settings": {
				"foreground": "#00CED1",
				"fontStyle": "bold"
			}
		},
		{
			"name": "Regex - Genjutsu patterns",
			"scope": ["string.regexp"],
			"settings": {
				"foreground": "#9370DB"
			}
		},
		{
			"name": "Numbers - Tomoe count",
			"scope": ["constant.numeric", "constant.language"],
			"settings": {
				"foreground": "#FFD700"
			}
		},
		{
			"name": "Booleans - True power",
			"scope": ["constant.language.boolean"],
			"settings": {
				"foreground": "#ff3388",
				"fontStyle": "bold"
			}
		},
		{
			"name": "Variables - Shinobi arsenal",
			"scope": ["variable", "variable.other"],
			"settings": {
				"foreground": "#e8e8f0"
			}
		},
		{
			"name": "Parameters - Jutsu components",
			"scope": ["variable.parameter"],
			"settings": {
				"foreground": "#b8b8d8",
				"fontStyle": "italic"
			}
		},
		{
			"name": "Properties - Uchiha abilities",
			"scope": ["variable.other.property", "support.variable.property"],
			"settings": {
				"foreground": "#c8c8dc"
			}
		},
		{
			"name": "Functions - Jutsu techniques",
			"scope": ["entity.name.function", "support.function"],
			"settings": {
				"foreground": "#9370DB",
				"fontStyle": "bold"
			}
		},
		{
			"name": "Function Calls - Activating jutsu",
			"scope": ["meta.function-call"],
			"settings": {
				"foreground": "#8b7ddb"
			}
		},
		{
			"name": "Classes - Uchiha clan",
			"scope": ["entity.name.type", "entity.name.class", "support.class"],
			"settings": {
				"foreground": "#FF0066",
				"fontStyle": ""
			}
		},
		{
			"name": "Inherited Classes - Bloodline limit",
			"scope": ["entity.other.inherited-class"],
			"settings": {
				"foreground": "#ff3388",
				"fontStyle": "italic"
			}
		},
		{
			"name": "HTML Tags - Sealing jutsu",
			"scope": ["entity.name.tag"],
			"settings": {
				"foreground": "#8b00ff",
				"fontStyle": "bold"
			}
		},
		{
			"name": "HTML Attributes - Seal properties",
			"scope": ["entity.other.attribute-name"],
			"settings": {
				"foreground": "#9370DB",
				"fontStyle": "italic"
			}
		},
		{
			"name": "CSS Selectors - Target lock",
			"scope": ["entity.name.tag.css", "entity.other.attribute-name.class.css"],
			"settings": {
				"foreground": "#FF0066"
			}
		},
		{
			"name": "CSS Properties - Style jutsu",
			"scope": ["support.type.property-name.css"],
			"settings": {
				"foreground": "#4169E1"
			}
		},
		{
			"name": "CSS Values - Transformation",
			"scope": ["support.constant.property-value.css"],
			"settings": {
				"foreground": "#FFD700"
			}
		},
		{
			"name": "Support Types - Chakra nature",
			"scope": ["support.type", "support.class"],
			"settings": {
				"foreground": "#8b7ddb"
			}
		},
		{
			"name": "Support Constants - Eternal power",
			"scope": ["support.constant"],
			"settings": {
				"foreground": "#ff3388"
			}
		},
		{
			"name": "JSON Keys - Data scroll",
			"scope": ["support.type.property-name.json"],
			"settings": {
				"foreground": "#9370DB"
			}
		},
		{
			"name": "Operators - Combat style",
			"scope": ["keyword.operator"],
			"settings": {
				"foreground": "#FF0066"
			}
		},
		{
			"name": "Punctuation - Kunai strikes",
			"scope": ["punctuation"],
			"settings": {
				"foreground": "#8a8aaa"
			}
		},
		{
			"name": "Punctuation Definition - Precise hits",
			"scope": [
				"punctuation.definition.string",
				"punctuation.definition.parameters",
				"punctuation.definition.array"
			],
			"settings": {
				"foreground": "#7a7a9a"
			}
		},
		{
			"name": "Meta Braces - Seal formation",
			"scope": ["meta.brace", "punctuation.section"],
			"settings": {
				"foreground": "#c8c8dc"
			}
		},
		{
			"name": "Invalid - Amaterasu flames",
			"scope": ["invalid"],
			"settings": {
				"foreground": "#ffffff"
			}
		},
		{
			"name": "Deprecated - Old techniques",
			"scope": ["invalid.deprecated"],
			"settings": {
				"foreground": "#5a5a7a",
				"fontStyle": "strikethrough"
			}
		},
		{
			"name": "Markdown Headings - Mission ranks",
			"scope": ["markup.heading"],
			"settings": {
				"foreground": "#FF0066",
				"fontStyle": "bold"
			}
		},
		{
			"name": "Markdown Bold - Power emphasis",
			"scope": ["markup.bold"],
			"settings": {
				"foreground": "#8b00ff",
				"fontStyle": "bold"
			}
		},
		{
			"name": "Markdown Italic - Swift movement",
			"scope": ["markup.italic"],
			"settings": {
				"foreground": "#9370DB",
				"fontStyle": "italic"
			}
		},
		{
			"name": "Markdown Code - Scroll content",
			"scope": ["markup.inline.raw"],
			"settings": {
				"foreground": "#4169E1"
			}
		},
		{
			"name": "Markdown Links - Dimensional portals",
			"scope": ["markup.underline.link"],
			"settings": {
				"foreground": "#00CED1",
				"fontStyle": "underline"
			}
		},
		{
			"name": "Markdown Lists - Battle tactics",
			"scope": ["markup.list"],
			"settings": {
				"foreground": "#FFD700"
			}
		},
		{
			"name": "Diff Inserted - Victory",
			"scope": ["markup.inserted"],
			"settings": {
				"foreground": "#4169E1"
			}
		},
		{
			"name": "Diff Deleted - Defeat",
			"scope": ["markup.deleted"],
			"settings": {
				"foreground": "#FF0066"
			}
		},
		{
			"name": "Diff Changed - Evolution",
			"scope": ["markup.changed"],
			"settings": {
				"foreground": "#FFD700"
			}
		},
		{
			"name": "TypeScript/JavaScript - This keyword",
			"scope": ["variable.language.this"],
			"settings": {
				"foreground": "#FF0066",
				"fontStyle": "italic"
			}
		},
		{
			"name": "TypeScript Types - Kekkei Genkai",
			"scope": ["entity.name.type.ts", "entity.name.type.tsx"],
			"settings": {
				"foreground": "#ff3388"
			}
		},
		{
			"name": "Decorators - Curse marks",
			"scope": ["meta.decorator", "punctuation.decorator"],
			"settings": {
				"foreground": "#8b00ff",
				"fontStyle": "bold"
			}
		},
		{
			"name": "Python Self - Inner power",
			"scope": ["variable.language.special.self.python"],
			"settings": {
				"foreground": "#FF0066",
				"fontStyle": "italic"
			}
		},
		{
			"name": "Python Decorators - Technique seals",
			"scope": ["entity.name.function.decorator.python"],
			"settings": {
				"foreground": "#8b00ff"
			}
		}
	]
}
