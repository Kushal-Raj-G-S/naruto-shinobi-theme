	"tokenColors": [
		{
			"name": "Comments - Strategic notes",
			"scope": ["comment", "punctuation.definition.comment"],
			"settings": {
				"foreground": "#5a7a9a",
				"fontStyle": "italic"
			}
		},
		{
			"name": "Keywords - FLASH ESSENCE",
			"scope": ["keyword", "storage.type", "storage.modifier"],
			"settings": {
				"foreground": "#FFA500",
				"fontStyle": "bold"
			}
		},
		{
			"name": "Control Flow - INSTANT MOVEMENT",
			"scope": ["keyword.control", "keyword.operator"],
			"settings": {
				"foreground": "#FFD700",
				"fontStyle": "bold"
			}
		},
		{
			"name": "Import/Export - SUMMONING TECHNIQUE",
			"scope": [
				"keyword.control.import",
				"keyword.control.export",
				"keyword.control.from",
				"keyword.control.as"
			],
			"settings": {
				"foreground": "#87CEEB",
				"fontStyle": ""
			}
		},
		{
			"name": "Strings - SEAL FORMULA",
			"scope": ["string", "string.quoted"],
			"settings": {
				"foreground": "#FFFFFF"
			}
		},
		{
			"name": "Template Strings - JUTSU INCANTATION",
			"scope": ["string.template", "string.quoted.template"],
			"settings": {
				"foreground": "#F5F5DC"
			}
		},
		{
			"name": "String Escape - HIRAISHIN MARK",
			"scope": ["constant.character.escape"],
			"settings": {
				"foreground": "#FFD700",
				"fontStyle": "bold"
			}
		},
		{
			"name": "Regex - FORMULA PATTERN",
			"scope": ["string.regexp"],
			"settings": {
				"foreground": "#FFA500"
			}
		},
		{
			"name": "Numbers - SPEED COUNT",
			"scope": ["constant.numeric", "constant.language"],
			"settings": {
				"foreground": "#FFEA00",
				"fontStyle": "bold"
			}
		},
		{
			"name": "Booleans - HOKAGE TRUTH",
			"scope": ["constant.language.boolean"],
			"settings": {
				"foreground": "#00BFFF",
				"fontStyle": "bold"
			}
		},
		{
			"name": "Variables - YELLOW FLASH GOLD",
			"scope": ["variable", "variable.other"],
			"settings": {
				"foreground": "#FFD700",
				"fontStyle": ""
			}
		},
		{
			"name": "Parameters - TECHNIQUE PARAMS",
			"scope": ["variable.parameter"],
			"settings": {
				"foreground": "#FFA500",
				"fontStyle": "italic"
			}
		},
		{
			"name": "Properties - KUNAI DETAILS",
			"scope": ["variable.other.property", "support.variable.property"],
			"settings": {
				"foreground": "#F0E68C"
			}
		},
		{
			"name": "Functions - BLUE RASENGAN",
			"scope": ["entity.name.function", "support.function"],
			"settings": {
				"foreground": "#00BFFF",
				"fontStyle": "bold"
			}
		},
		{
			"name": "Function Calls - JUTSU EXECUTION",
