  "semanticTokenColors": {
    "namespace": "#17A2B8",
    "class": "#17A2B8",
    "interface": "#00CED1",
    "enum": "#FFD700",
    "enumMember": "#F39C12",
    "type": "#17A2B8",
    "typeParameter": "#00A8E8",
    "parameter": "#00A8E8",
    "variable": "#00A8E8",
    "property": "#5DADE2",
    "function": "#8E44AD",
    "method": "#8E44AD",
    "macro": "#FFB84D",
    "keyword": "#FFA500",
    "comment": "#808080",
    "string": "#27AE60",
    "number": "#F39C12",
    "regexp": "#4CAF50",
    "operator": "#FFB84D"
  },
  "tokenColors": [
    {
      "name": "Comments",
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#808080",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Documentation Comments",
      "scope": [
        "comment.block.documentation",
        "comment.line.documentation"
      ],
      "settings": {
        "foreground": "#95A5A6",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Keywords",
      "scope": [
        "keyword",
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#FFA500",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Control Keywords",
      "scope": [
        "keyword.control",
        "keyword.control.flow"
      ],
      "settings": {
        "foreground": "#FFB84D",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Import/Export Keywords",
      "scope": [
        "keyword.control.import",
        "keyword.control.export",
        "keyword.control.from"
      ],
      "settings": {
        "foreground": "#FFA500"
      }
    },
    {
      "name": "Strings",
      "scope": [
        "string",
        "string.quoted",
        "string.quoted.double",
        "string.quoted.single",
        "string.quoted.triple"
      ],
      "settings": {
        "foreground": "#27AE60"
      }
    },
    {
      "name": "Template Strings",
      "scope": [
        "string.template",
        "string.quoted.template"
      ],
      "settings": {
        "foreground": "#27AE60"
      }
    },
    {
      "name": "String Escape Sequences",
      "scope": [
        "constant.character.escape",
        "constant.other.placeholder"
      ],
      "settings": {
        "foreground": "#4CAF50",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Regular Expressions",
      "scope": [
        "string.regexp"
      ],
      "settings": {
        "foreground": "#4CAF50"
      }
    },
    {
      "name": "Functions & Methods",
      "scope": [
        "entity.name.function",
        "support.function",
        "meta.function-call.generic"
      ],
      "settings": {
        "foreground": "#8E44AD"
      }
    },
    {
      "name": "Function Calls",
      "scope": [
        "meta.function-call"
      ],
      "settings": {
        "foreground": "#9C27B0"
      }
    },
    {
      "name": "Function Parameters",
      "scope": [
        "variable.parameter",
        "meta.parameters"
      ],
      "settings": {
        "foreground": "#00A8E8"
      }
    },
    {
      "name": "Variables",
      "scope": [
        "variable",
        "support.variable"
      ],
      "settings": {
        "foreground": "#00A8E8"
      }
    },
    {
      "name": "Variable Declarations",
      "scope": [
        "variable.other.declaration",
        "meta.definition.variable"
      ],
      "settings": {
        "foreground": "#5DADE2"
      }
    },
    {
      "name": "Object Properties",
      "scope": [
        "variable.object.property",
        "variable.other.property",
        "meta.object-literal.key"
      ],
      "settings": {
        "foreground": "#5DADE2"
      }
    },
    {
      "name": "This/Self Keywords",
      "scope": [
        "variable.language.this",
        "variable.language.self",
        "variable.language.super"
      ],
      "settings": {
        "foreground": "#FFB84D",
        "fontStyle": "italic bold"
      }
    },
    {
      "name": "Classes & Types",
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "support.class",
        "entity.other.inherited-class"
      ],
      "settings": {
        "foreground": "#17A2B8",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Interfaces",
      "scope": [
        "entity.name.type.interface"
      ],
      "settings": {
        "foreground": "#00CED1",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Type Annotations",
      "scope": [
        "meta.type.annotation",
        "support.type"
      ],
      "settings": {
        "foreground": "#17A2B8"
      }
    },
    {
      "name": "Constants",
      "scope": [
        "constant",
        "variable.other.constant",
        "support.constant"
      ],
      "settings": {
        "foreground": "#FFD700"
      }
    },
    {
      "name": "Numbers",
      "scope": [
        "constant.numeric",
        "constant.numeric.integer",
        "constant.numeric.float",
        "constant.numeric.hex",
        "constant.numeric.binary",
        "constant.numeric.octal"
      ],
      "settings": {
        "foreground": "#F39C12"
      }
    },
    {
      "name": "Booleans",
      "scope": [
        "constant.language.boolean",
        "constant.language.true",
        "constant.language.false"
      ],
      "settings": {
        "foreground": "#E67E22",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Null/Undefined/None",
      "scope": [
        "constant.language.null",
        "constant.language.undefined",
