  "semanticTokenColors": {
    "namespace": "#00CED1",
    "class": "#00CED1",
    "interface": "#17A2B8",
    "enum": "#FFD700",
    "enumMember": "#FFC107",
    "type": "#00CED1",
    "typeParameter": "#5DADE2",
    "parameter": "#5DADE2",
    "variable": "#5DADE2",
    "property": "#4A90E2",
    "function": "#9C27B0",
    "method": "#9C27B0",
    "macro": "#FF8C00",
    "keyword": "#FF6B00",
    "comment": "#6C6C6C",
    "string": "#4CAF50",
    "number": "#FFC107",
    "regexp": "#27AE60",
    "operator": "#FF8C00"
  },
  "tokenColors": [
    {
      "name": "Comments",
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#6C6C6C",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Documentation Comments",
      "scope": [
        "comment.block.documentation",
        "comment.line.documentation"
      ],
      "settings": {
        "foreground": "#808080",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Keywords",
      "scope": [
        "keyword",
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#FF6B00",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Control Keywords",
      "scope": [
        "keyword.control",
        "keyword.control.flow"
      ],
      "settings": {
        "foreground": "#FF8C00",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Import/Export Keywords",
      "scope": [
        "keyword.control.import",
        "keyword.control.export",
        "keyword.control.from"
      ],
      "settings": {
        "foreground": "#FF6B00"
      }
    },
    {
      "name": "Strings",
      "scope": [
        "string",
        "string.quoted",
        "string.quoted.double",
        "string.quoted.single",
        "string.quoted.triple"
      ],
      "settings": {
        "foreground": "#4CAF50"
      }
    },
    {
      "name": "Template Strings",
      "scope": [
        "string.template",
        "string.quoted.template"
      ],
      "settings": {
        "foreground": "#4CAF50"
      }
    },
    {
      "name": "String Escape Sequences",
      "scope": [
        "constant.character.escape",
        "constant.other.placeholder"
      ],
      "settings": {
        "foreground": "#27AE60",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Regular Expressions",
      "scope": [
        "string.regexp"
      ],
      "settings": {
        "foreground": "#27AE60"
      }
    },
    {
      "name": "Functions & Methods",
      "scope": [
        "entity.name.function",
        "support.function",
        "meta.function-call.generic"
      ],
      "settings": {
        "foreground": "#9C27B0"
      }
    },
    {
      "name": "Function Calls",
      "scope": [
        "meta.function-call"
      ],
      "settings": {
        "foreground": "#8E44AD"
      }
    },
    {
      "name": "Function Parameters",
      "scope": [
        "variable.parameter",
        "meta.parameters"
      ],
      "settings": {
        "foreground": "#5DADE2"
      }
    },
    {
      "name": "Variables",
      "scope": [
        "variable",
        "support.variable"
      ],
      "settings": {
        "foreground": "#5DADE2"
      }
    },
    {
      "name": "Variable Declarations",
      "scope": [
        "variable.other.declaration",
        "meta.definition.variable"
      ],
      "settings": {
        "foreground": "#4A90E2"
      }
    },
    {
      "name": "Object Properties",
      "scope": [
        "variable.object.property",
        "variable.other.property",
        "meta.object-literal.key"
      ],
      "settings": {
        "foreground": "#4A90E2"
      }
    },
    {
      "name": "This/Self Keywords",
      "scope": [
        "variable.language.this",
        "variable.language.self",
        "variable.language.super"
      ],
      "settings": {
        "foreground": "#FF8C00",
        "fontStyle": "italic bold"
      }
    },
    {
      "name": "Classes & Types",
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "support.class",
        "entity.other.inherited-class"
      ],
      "settings": {
        "foreground": "#00CED1",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Interfaces",
      "scope": [
        "entity.name.type.interface"
      ],
      "settings": {
        "foreground": "#17A2B8",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Type Annotations",
      "scope": [
        "meta.type.annotation",
        "support.type"
      ],
      "settings": {
        "foreground": "#00CED1"
      }
    },
    {
      "name": "Constants",
      "scope": [
        "constant",
        "variable.other.constant",
        "support.constant"
      ],
      "settings": {
        "foreground": "#FFD700"
      }
    },
    {
      "name": "Numbers",
      "scope": [
        "constant.numeric",
        "constant.numeric.integer",
        "constant.numeric.float",
        "constant.numeric.hex",
        "constant.numeric.binary",
