	"tokenColors": [
		{
			"name": "Comments - Whispered memories",
			"scope": ["comment", "punctuation.definition.comment"],
			"settings": {
				"foreground": "#6a3a3a",
				"fontStyle": "italic"
			}
		},
		{
			"name": "Keywords - FIERY ESSENCE",
			"scope": ["keyword", "storage.type", "storage.modifier"],
			"settings": {
				"foreground": "#FF4500",
				"fontStyle": "bold"
			}
		},
		{
			"name": "Control Flow - PASSIONATE CONTROL",
			"scope": ["keyword.control", "keyword.operator"],
			"settings": {
				"foreground": "#FF6347",
				"fontStyle": "bold"
			}
		},
		{
			"name": "Import/Export - UZUMAKI SUMMONING",
			"scope": [
				"keyword.control.import",
				"keyword.control.export",
				"keyword.control.from",
				"keyword.control.as"
			],
			"settings": {
				"foreground": "#FFA500",
				"fontStyle": ""
			}
		},
		{
			"name": "Strings - WARM ORANGE WORDS",
			"scope": ["string", "string.quoted"],
			"settings": {
				"foreground": "#FF8C00"
			}
		},
		{
			"name": "Template Strings - LOVING INCANTATION",
			"scope": ["string.template", "string.quoted.template"],
			"settings": {
				"foreground": "#FFA500"
			}
		},
		{
			"name": "String Escape - CHAIN BREAK",
