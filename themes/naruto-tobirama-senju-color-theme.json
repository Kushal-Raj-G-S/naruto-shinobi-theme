  "tokenColors": [
    {
      "name": "Comments",
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#5A7A8F",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Documentation Comments",
      "scope": [
        "comment.block.documentation",
        "comment.line.documentation"
      ],
      "settings": {
        "foreground": "#7A9FB5",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Keywords",
      "scope": [
        "keyword",
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#00CED1",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Control Keywords",
      "scope": [
        "keyword.control",
        "keyword.control.flow"
      ],
      "settings": {
        "foreground": "#4FC3F7",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Import/Export Keywords",
      "scope": [
        "keyword.control.import",
        "keyword.control.export",
        "keyword.control.from"
      ],
      "settings": {
        "foreground": "#00CED1"
      }
    },
    {
      "name": "Strings",
      "scope": [
        "string",
        "string.quoted",
        "string.quoted.double",
        "string.quoted.single",
        "string.quoted.triple"
      ],
      "settings": {
        "foreground": "#5DADE2"
      }
    },
    {
      "name": "Template Strings",
      "scope": [
        "string.template",
        "string.quoted.template"
      ],
      "settings": {
        "foreground": "#5DADE2"
      }
    },
    {
      "name": "String Escape Sequences",
      "scope": [
        "constant.character.escape",
        "constant.other.placeholder"
      ],
      "settings": {
        "foreground": "#18FFFF",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Regular Expressions",
      "scope": [
        "string.regexp"
      ],
      "settings": {
        "foreground": "#18FFFF"
      }
    },
    {
      "name": "Functions & Methods",
      "scope": [
        "entity.name.function",
        "support.function",
        "meta.function-call.generic"
      ],
      "settings": {
        "foreground": "#9C88FF"
      }
    },
    {
      "name": "Function Calls",
      "scope": [
        "meta.function-call"
      ],
      "settings": {
        "foreground": "#B39DDB"
      }
    },
    {
      "name": "Function Parameters",
      "scope": [
        "variable.parameter",
        "meta.parameters"
      ],
      "settings": {
        "foreground": "#4FC3F7"
      }
    },
    {
      "name": "Variables",
      "scope": [
        "variable",
        "support.variable"
      ],
      "settings": {
        "foreground": "#4FC3F7"
      }
    },
    {
      "name": "Variable Declarations",
      "scope": [
        "variable.other.declaration",
        "meta.definition.variable"
      ],
      "settings": {
        "foreground": "#81D4FA"
      }
    },
    {
      "name": "Object Properties",
      "scope": [
        "variable.object.property",
        "variable.other.property",
        "meta.object-literal.key"
      ],
      "settings": {
        "foreground": "#81D4FA"
      }
    },
    {
      "name": "This/Self Keywords",
      "scope": [
        "variable.language.this",
        "variable.language.self",
        "variable.language.super"
      ],
      "settings": {
        "foreground": "#4FC3F7",
        "fontStyle": "italic bold"
      }
    },
    {
      "name": "Classes & Types",
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "support.class",
        "entity.other.inherited-class"
      ],
      "settings": {
        "foreground": "#00CED1",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Interfaces",
      "scope": [
        "entity.name.type.interface"
      ],
      "settings": {
        "foreground": "#80DEEA",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Type Annotations",
      "scope": [
        "meta.type.annotation",
        "support.type"
      ],
      "settings": {
        "foreground": "#00CED1"
      }
    },
    {
      "name": "Constants",
      "scope": [
        "constant",
        "variable.other.constant",
        "support.constant"
      ],
      "settings": {
        "foreground": "#E0F7FA"
      }
    },
    {
      "name": "Numbers",
      "scope": [
        "constant.numeric",
        "constant.numeric.integer",
        "constant.numeric.float",
